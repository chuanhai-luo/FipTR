{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "create_dataset",
            "type": "debugpy",
            "request": "launch",
            "program": "tools/create_data.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}",
                "OMP_NUM_THREADS": "4",
            },
            "args": [
                "nuscenes",
                "--root-path", "${workspaceFolder}/data/nuscenes",
                "--out-dir", "${workspaceFolder}/data/nuscenes",
                "--extra-tag", "nuscenes",
                "--version", "v1.0-mini",
            ]
        },
        {
            "name": "eval",
            "type": "debugpy",
            "request": "launch",
            "program": "tools/test.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}",
                "OMP_NUM_THREADS": "4",
            },
            "args": [
                "projects/configs/fiptr_lss_tiny/FipTR_LSS_Tiny.py",
                // "projects/configs/fiptr_lss_tiny/FipTR_LSS_Tiny_CBGS.py",
                // "projects/configs/fiptr_lss_tiny/FipTR_LSS_Tiny_SyncBN.py",
                "ckpts/fiptr_tiny.pth",
                // "ckpts/fiptr_tiny_cbgs.pth",
                // "ckpts/fiptr_tiny_syncbn.pth",
                "--launcher", "none",
                "--eval", "bbox"
            ]
        },
        {
            "name": "train",
            "type": "debugpy",
            "request": "launch",
            "program": "tools/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder):${env:PYTHONPATH)",
                "CUDA_LAUNCH_BLOCKING": "1",
                "OMP_NUM_THREADS": "4",
            },
            "args": [
                "projects/configs/fiptr_Iss_tiny/FipTR_LSS_Tiny.py",
                // "projects/configs/fiptr_Iss_tiny/FipTR_LSS_Tiny_CBGS.py",
                // "projects/configs/fiptr_Iss_tiny/FipTR_LSS_Tiny_SyncBN.py",
                "--launcher", "none",
                "--deterministic",
            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}